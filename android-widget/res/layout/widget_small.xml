<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/w_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
        <View android:id="@+id/w_live" android:layout_width="6dp" android:layout_height="6dp"
            android:layout_marginEnd="5dp" android:background="@color/wc_red"/>
        <TextView android:id="@+id/w_status" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="@color/wc_green" android:textSize="10sp"
            android:textStyle="bold"/>
        <TextView android:id="@+id/w_emblem" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="26" android:textColor="@color/wc_green" android:textStyle="bold"
            android:textSize="12sp" android:contentDescription="Refresh"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal" android:gravity="center" android:paddingTop="8dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <ImageView android:id="@+id/w_home_flag" android:layout_width="30dp" android:layout_height="20dp"
                android:scaleType="fitCenter" android:contentDescription="home"/>
            <TextView android:id="@+id/w_home" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/wc_text" android:textSize="11sp" android:textStyle="bold"
                android:paddingTop="4dp" android:maxLines="1"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <ImageView android:id="@+id/w_away_flag" android:layout_width="30dp" android:layout_height="20dp"
                android:scaleType="fitCenter" android:contentDescription="away"/>
            <TextView android:id="@+id/w_away" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/wc_text" android:textSize="11sp" android:textStyle="bold"
                android:paddingTop="4dp" android:maxLines="1"/>
        </LinearLayout>
    </LinearLayout>

    <TextView android:id="@+id/w_score" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center" android:textColor="@color/wc_text" android:textSize="26sp"
        android:textStyle="bold" android:paddingTop="2dp"/>
</LinearLayout>
